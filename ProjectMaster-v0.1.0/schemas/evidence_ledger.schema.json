{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://projectmaster.local/schemas/evidence_ledger.schema.json",
  "title": "Evidence Ledger Claim",
  "type": "object",
  "required": ["statement", "status", "confidence", "evidence", "missing_evidence"],
  "properties": {
    "id": {"type": ["integer", "null"]},
    "statement": {"type": "string", "minLength": 1},
    "status": {
      "type": "string",
      "enum": ["unverified", "supported", "contradicted", "mixed", "unknown"]
    },
    "confidence": {"type": "number", "minimum": 0, "maximum": 1},
    "evidence": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["stance", "summary", "reliability"],
        "properties": {
          "stance": {"enum": ["supports", "contradicts", "context"]},
          "source_type": {"type": "string"},
          "source_ref": {"type": "string"},
          "summary": {"type": "string"},
          "reliability": {"type": "number", "minimum": 0, "maximum": 1}
        }
      }
    },
    "missing_evidence": {"type": "array", "items": {"type": "string"}},
    "assessment": {"type": "string"},
    "revision_conditions": {"type": "array", "items": {"type": "string"}}
  }
}
