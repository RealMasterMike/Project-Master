{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://projectmaster.local/schemas/memory.schema.json",
  "title": "Project Master Memory",
  "type": "object",
  "required": ["namespace", "key", "value", "source", "confidence"],
  "properties": {
    "namespace": {
      "type": "string",
      "enum": ["user_preference", "project", "personal_context", "external_claim", "temporary"]
    },
    "key": {"type": "string", "minLength": 1},
    "value": {},
    "source": {"type": "string", "minLength": 1},
    "confidence": {"type": "number", "minimum": 0, "maximum": 1},
    "created_at": {"type": "string", "format": "date-time"},
    "updated_at": {"type": "string", "format": "date-time"}
  }
}
